{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-lan-control.schema.json",
  "title": "Codex LAN Control Protocol",
  "description": "Versioned JSON-over-WebSocket protocol between the mobile controller and local host bridge.",
  "version": 2,
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/PairingClaim" },
    { "$ref": "#/$defs/AuthResume" },
    { "$ref": "#/$defs/AuthPassword" },
    { "$ref": "#/$defs/SessionStart" },
    { "$ref": "#/$defs/SessionList" },
    { "$ref": "#/$defs/SessionCreate" },
    { "$ref": "#/$defs/SessionRename" },
    { "$ref": "#/$defs/SessionDelete" },
    { "$ref": "#/$defs/SessionModeSet" },
    { "$ref": "#/$defs/SessionConfigSet" },
    { "$ref": "#/$defs/WorkspaceList" },
    { "$ref": "#/$defs/WorkspaceAdd" },
    { "$ref": "#/$defs/WorkspaceSwitch" },
    { "$ref": "#/$defs/ExternalSessionList" },
    { "$ref": "#/$defs/ExternalSessionImport" },
    { "$ref": "#/$defs/CommandList" },
    { "$ref": "#/$defs/CommandRun" },
    { "$ref": "#/$defs/PromptSend" },
    { "$ref": "#/$defs/RunCancel" },
    { "$ref": "#/$defs/Ping" }
  ],
  "$defs": {
    "PairingClaim": {
      "type": "object",
      "required": ["type", "pairingToken", "deviceName"],
      "properties": {
        "type": { "const": "pairing.claim" },
        "pairingToken": { "type": "string", "minLength": 16 },
        "deviceName": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "AuthResume": {
      "type": "object",
      "required": ["type", "deviceToken"],
      "properties": {
        "type": { "const": "auth.resume" },
        "deviceToken": { "type": "string", "minLength": 16 }
      }
    },
    "AuthPassword": {
      "type": "object",
      "required": ["type", "password", "deviceName"],
      "properties": {
        "type": { "const": "auth.password" },
        "password": { "type": "string", "minLength": 1, "maxLength": 256 },
        "deviceName": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "SessionStart": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "session.start" },
        "sessionId": { "type": "string" }
      }
    },
    "SessionList": {
      "type": "object",
      "required": ["type"],
      "properties": { "type": { "const": "session.list" } }
    },
    "SessionCreate": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "session.create" },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 },
        "workspaceId": { "type": "string" },
        "mode": { "enum": ["safe", "yolo"] }
      }
    },
    "SessionRename": {
      "type": "object",
      "required": ["type", "sessionId", "title"],
      "properties": {
        "type": { "const": "session.rename" },
        "sessionId": { "type": "string" },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "SessionDelete": {
      "type": "object",
      "required": ["type", "sessionId"],
      "properties": {
        "type": { "const": "session.delete" },
        "sessionId": { "type": "string" }
      }
    },
    "SessionModeSet": {
      "type": "object",
      "required": ["type", "sessionId", "mode"],
      "properties": {
        "type": { "const": "session.mode.set" },
        "sessionId": { "type": "string" },
        "mode": { "enum": ["safe", "yolo"] }
      }
    },
    "SessionConfigSet": {
      "type": "object",
      "required": ["type", "sessionId"],
      "properties": {
        "type": { "const": "session.config.set" },
        "sessionId": { "type": "string" },
        "model": { "type": "string", "maxLength": 120 },
        "reasoningEffort": { "enum": ["low", "medium", "high", "xhigh"] }
      }
    },
    "WorkspaceList": {
      "type": "object",
      "required": ["type"],
      "properties": { "type": { "const": "workspace.list" } }
    },
    "WorkspaceAdd": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": { "const": "workspace.add" },
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "sessionId": { "type": "string" },
        "create": { "type": "boolean" }
      }
    },
    "WorkspaceSwitch": {
      "type": "object",
      "required": ["type", "sessionId", "workspaceId"],
      "properties": {
        "type": { "const": "workspace.switch" },
        "sessionId": { "type": "string" },
        "workspaceId": { "type": "string" }
      }
    },
    "ExternalSessionList": {
      "type": "object",
      "required": ["type"],
      "properties": { "type": { "const": "external.session.list" } }
    },
    "ExternalSessionImport": {
      "type": "object",
      "required": ["type", "externalSessionId"],
      "properties": {
        "type": { "const": "external.session.import" },
        "externalSessionId": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "CommandList": {
      "type": "object",
      "required": ["type"],
      "properties": { "type": { "const": "command.list" } }
    },
    "CommandRun": {
      "type": "object",
      "required": ["type", "commandId"],
      "properties": {
        "type": { "const": "command.run" },
        "commandId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "sessionId": { "type": "string" }
      }
    },
    "PromptSend": {
      "type": "object",
      "required": ["type", "sessionId", "prompt"],
      "properties": {
        "type": { "const": "prompt.send" },
        "sessionId": { "type": "string" },
        "prompt": { "type": "string", "minLength": 1, "maxLength": 65536 },
        "attachments": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["name", "dataBase64"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 160 },
              "mimeType": { "type": "string", "minLength": 1, "maxLength": 120 },
              "dataBase64": { "type": "string", "minLength": 1, "maxLength": 8388608 }
            }
          }
        }
      }
    },
    "RunCancel": {
      "type": "object",
      "required": ["type", "sessionId", "runId"],
      "properties": {
        "type": { "const": "run.cancel" },
        "sessionId": { "type": "string" },
        "runId": { "type": "string" }
      }
    },
    "Ping": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "ping" },
        "nonce": { "type": "string" }
      }
    }
  }
}
