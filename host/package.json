{
  "name": "codex-link-host",
  "version": "0.1.2",
  "type": "module",
  "description": "Host bridge for controlling Codex app-server sessions from Codex Link.",
  "license": "MIT",
  "bin": {
    "codex-link-host": "dist/src/index.js"
  },
  "files": [
    "dist/src/**/*",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "update:self": "../scripts/update-host.sh"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pino": "^9.4.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
